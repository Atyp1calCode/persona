# LLM — choose one backend

# Option A: Ollama (local, no API key needed)
OLLAMA_URL=http://localhost:11434/v1
OLLAMA_MODEL=llama3.2

# Option B: OpenRouter (cloud)
# OPENROUTER_API_KEY=your-openrouter-key-here
# OPENROUTER_MODEL=openai/gpt-4o-mini

# Embeddings
# When using Ollama, defaults to Ollama (nomic-embed-text) — no extra config needed.
# When using OpenRouter, defaults to OpenAI embeddings API (text-embedding-3-small).
# OPENAI_API_KEY=your-openai-key-here

# Override embedding service entirely (any OpenAI-compatible endpoint):
# EMBED_BASE_URL=https://api.openai.com/v1
# EMBED_API_KEY=your-key-here
# EMBED_MODEL=text-embedding-3-small

# Chatbot
SYSTEM_PROMPT=You are a helpful assistant.

# Storage
LANCEDB_PATH=./data/lancedb

# Web server
PORT=3000

# Telegram (only needed for telegram mode)
# TELEGRAM_BOT_TOKEN=your-token-here
# TELEGRAM_ALLOWED_IDS=123456789,987654321
